# ─────────────────────────────────────────────────────────────
# Instagram AutoDM — Environment Variables
# On Railway: add these under Project → Variables (NOT as a file)
# Locally: rename this to .env — python-dotenv loads it automatically
# ─────────────────────────────────────────────────────────────

# 1. Your Instagram Page Access Token (never share this)
#    Get it from: Meta Developer Dashboard → Tools → Graph API Explorer
#    Required permissions: instagram_manage_messages, pages_messaging
IG_ACCESS_TOKEN=your_instagram_page_access_token_here

# 2. A random secret YOU make up — used once during webhook setup in Meta Dashboard
#    Can be anything, e.g.: mysecret_autodm_2024
WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

# 3. Port — Railway sets this automatically, do not change
PORT=3000
